# ---- Supabase ---------------------------------------------------------------
# Vercel Project Settings > Environment Variables 에서 동일한 키로 등록.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role — 서버 전용. 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것.
# 체크인 플로우처럼 익명 사용자를 대신해 쓰는 경로에서만 사용.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
